{
	"name": "opencut",
	"packageManager": "bun@1.2.18",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev:web": "cd apps/web && bun run dev",
		"dev:web:low-mem": "node scripts/dev-web-low-mem.mjs",
		"e2e:shared-profile": "node scripts/e2e-shared-profile.mjs",
		"e2e:observe:text-edit": "node scripts/observe-text-edit-session.mjs",
		"e2e:test:caption-trim-sync": "node scripts/test-caption-trim-sync.mjs",
		"e2e:test:caption-edit-playback-integrity": "node scripts/test-caption-edit-playback-integrity.mjs",
		"e2e:test:audio-playback-stress-ui": "node scripts/test-audio-playback-stress-ui.mjs",
		"e2e:test:audio-move-overlap-ui": "node scripts/test-audio-move-overlap-ui.mjs",
		"mem:audit": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/memory-doctor.ps1 -Mode audit",
		"mem:reduce": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/memory-doctor.ps1 -Mode reduce",
		"mem:reduce:aggressive": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/memory-doctor.ps1 -Mode reduce -Aggressive",
		"build:web": "cd apps/web && bun run build",
		"kill:playwright": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/kill-playwright-sessions.ps1",
		"docker:up": "node scripts/docker-preflight.mjs && node scripts/docker-up.mjs full",
		"docker:up:core": "node scripts/docker-preflight.mjs && node scripts/docker-up.mjs core",
		"docker:up:web": "node scripts/docker-preflight.mjs && node scripts/docker-up.mjs web",
		"docker:rebuild": "node scripts/docker-preflight.mjs && node scripts/docker-up.mjs full --build",
		"docker:rebuild:transcribe-base": "node scripts/docker-preflight.mjs && node scripts/docker-up.mjs full --build-base --build",
		"docker:rebuild:core": "node scripts/docker-preflight.mjs && node scripts/docker-up.mjs core --build",
		"docker:rebuild:web": "node scripts/docker-preflight.mjs && node scripts/docker-up.mjs web --build",
		"docker:down": "docker compose down",
		"docker:logs": "docker compose logs -f web local-transcribe",
		"docker:autostart:enable": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/register-opencut-startup.ps1",
		"docker:autostart:disable": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/unregister-opencut-startup.ps1",
		"dev:tools": "turbo run dev --filter=@opencut/tools",
		"build:tools": "turbo run build --filter=@opencut/tools",
		"start:tools": "turbo run start --filter=@opencut/tools",
		"lint:web": "biome lint apps/web/src --max-diagnostics=1000",
		"lint:web:fix": "biome lint apps/web/src --write --max-diagnostics=1000",
		"format:web": "biome format apps/web/src/services/renderer --write --max-diagnostics=1000",
		"test": "bun test",
		"generate:fonts": "npx tsx apps/web/scripts/generate-font-sprites.ts"
	},
	"dependencies": {
		"@types/react": "^19.2.10",
		"@types/react-dom": "^19.2.3",
		"better-auth": "^1.4.15",
		"next": "^16.1.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.5",
		"playwright": "^1.58.2",
		"turbo": "^2.7.5",
		"typescript": "5.8.3"
	},
	"trustedDependencies": [
		"@tailwindcss/oxide"
	]
}
