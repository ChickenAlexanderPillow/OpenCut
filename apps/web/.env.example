# Node
NODE_ENV=development

# Public
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_MARBLE_API_URL=https://api.marblecms.com
NEXT_PUBLIC_STORAGE_BACKEND=server

# Server
DATABASE_URL=postgresql://opencut:opencut@localhost:5432/opencut
BETTER_AUTH_SECRET=your_better_auth_secret

UPSTASH_REDIS_REST_URL=http://localhost:8079
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

MARBLE_WORKSPACE_KEY=your_marble_workspace_key

CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name

MODAL_TRANSCRIPTION_URL=https://example.com/transcribe
OPENAI_API_KEY=your_openai_api_key
LOCAL_TRANSCRIBE_ENABLED=true
LOCAL_TRANSCRIBE_URL=http://127.0.0.1:8765
LOCAL_TRANSCRIBE_TIMEOUT_MS=120000
LOCAL_TRANSCRIBE_API_KEY=
LOCAL_TRANSCRIBE_MODEL=large-v3
LOCAL_TRANSCRIBE_COMPUTE_TYPE=float16
LOCAL_TRANSCRIBE_DEVICE=cuda
LOCAL_TRANSCRIBE_FALLBACK_OPENAI=false
TRANSCRIPT_INGEST_SECRET=your_transcript_ingest_secret
EXTERNAL_PROJECTS_ENABLED=true
THUMBNAIL_API_BASE=http://localhost:9000
STORAGE_BACKEND=server
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=opencut
S3_SECRET_ACCESS_KEY=opencutsecret
S3_BUCKET=opencut-media
S3_FORCE_PATH_STYLE=true
# When running web in Docker and thumbnail API on host machine, use:
# THUMBNAIL_API_BASE=http://host.docker.internal:9000
DISABLE_RATE_LIMIT=false
